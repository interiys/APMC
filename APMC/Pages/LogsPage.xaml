<Page x:Class="APMC.Pages.LogsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:APMC.Pages"
      mc:Ignorable="d"
      Title="Журнал событий"
      Height="568" Width="907"
      Background="#F5F5F5"
      Loaded="Page_Loaded">

    <Grid Margin="-247,0,0,-216">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" 
                Background="#2196F3" 
                Padding="20"
                Height="80">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                          Text="Журнал событий системы"
                          FontSize="24" 
                          FontWeight="Bold" 
                          Foreground="White"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"/>

                <TextBlock x:Name="TBTotalLogs"
                          Grid.Column="1"
                          Text="Записей: 0"
                          FontSize="14" 
                          Foreground="White"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- Таблица логов -->
            <Border Grid.Column="0" 
                   Background="White"
                   CornerRadius="10"
                   Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Таблица внутри ScrollViewer для скроллбаров -->
                    <ScrollViewer Grid.Row="0"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 CanContentScroll="True">
                        <DataGrid x:Name="DGridLogs"
                                  AutoGenerateColumns="False"
                                  SelectionMode="Single" 
                                  HeadersVisibility="Column"
                                  BorderBrush="#E0E0E0"
                                  BorderThickness="1"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F8F8F8"
                                  FontSize="14"
                                  RowHeight="35"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False" Height="480" Width="744">
                            <DataGrid.Resources>
                                <!-- Стиль для заголовков колонок -->
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#2196F3"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="10,5"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Дата и время"
                                                   Binding="{Binding ActionTime, StringFormat=dd.MM.yyyy HH:mm}"
                                                   Width="150"/>
                                <DataGridTextColumn Header="Тип"
                                                   Binding="{Binding ActionType}"
                                                   Width="120"/>
                                <DataGridTextColumn Header="Пользователь" 
                                                   Binding="{Binding UserName}"
                                                   Width="120"/>
                                <DataGridTextColumn Header="Описание" 
                                                   Binding="{Binding ActionDescription}"
                                                   Width="*"
                                                   MinWidth="200"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Панель управления -->
            <Border Grid.Column="2" 
                   Margin="20,0,0,0"
                   Background="White"
                   CornerRadius="10"
                   Padding="15">
                <StackPanel>
                    <TextBlock Text="Управление"
                              FontSize="16"
                              FontWeight="Bold"
                              Foreground="#2196F3"
                              Margin="0,0,0,20"
                              HorizontalAlignment="Center"/>

                    <Button Content="Экспорт" 
                           Click="ButtonExport_Click"
                           Height="40"
                           FontSize="14"
                           Background="#4CAF50"
                           Foreground="White"
                           FontWeight="Bold"
                           Margin="0,0,0,10"
                           Cursor="Hand"/>

                    <Button Content="Очистить журнал" 
                           Click="ButtonClear_Click"
                           Height="40"
                           FontSize="14"
                           Background="#F44336"
                           Foreground="White"
                           FontWeight="Bold"
                           Margin="0,0,0,20"
                           Cursor="Hand"/>

                    <!-- Статистика -->
                    <Border Background="#E3F2FD"
                           CornerRadius="5"
                           Padding="10"
                           Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Статистика"
                                      FontSize="14"
                                      FontWeight="Bold"
                                      Foreground="#1976D2"
                                      Margin="0,0,0,10"
                                      HorizontalAlignment="Center"/>

                            <StackPanel Orientation="Horizontal"
                                       Margin="0,0,0,5">
                                <TextBlock Text="Всего:"
                                          FontSize="12"
                                          Foreground="#333333"/>
                                <TextBlock x:Name="TBTotalLogsCount"
                                          Text="0"
                                          FontSize="12"
                                          FontWeight="Bold"
                                          Foreground="#2196F3"
                                          Margin="5,0,0,0"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                       Margin="0,5,0,0">
                                <TextBlock Text="Ошибки:"
                                          FontSize="12"
                                          Foreground="#333333"/>
                                <TextBlock x:Name="TBErrorLogsCount"
                                          Text="0"
                                          FontSize="12"
                                          FontWeight="Bold"
                                          Foreground="#D32F2F"
                                          Margin="5,0,0,0"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                       Margin="0,5,0,0">
                                <TextBlock Text="Предупреждения:"
                                          FontSize="12"
                                          Foreground="#333333"/>
                                <TextBlock x:Name="TBWarningLogsCount"
                                          Text="0"
                                          FontSize="12"
                                          FontWeight="Bold"
                                          Foreground="#F57C00"
                                          Margin="5,0,0,0"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                       Margin="0,5,0,0">
                                <TextBlock Text="Информация:"
                                          FontSize="12"
                                          Foreground="#333333"/>
                                <TextBlock x:Name="TBInfoLogsCount"
                                          Text="0"
                                          FontSize="12"
                                          FontWeight="Bold"
                                          Foreground="#1976D2"
                                          Margin="5,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Нижняя панель -->
        <Border Grid.Row="1" 
               Background="#E8EAF6" 
               Padding="15"
               Height="70" Margin="0,573,0,61" Grid.RowSpan="2">
            <StackPanel Orientation="Horizontal" 
                       HorizontalAlignment="Right">
                <Button Content="Назад" 
                       Click="ButtonBack_Click"
                       Width="120" Height="40"
                       FontSize="14"
                       Background="#757575"
                       Foreground="White"
                       FontWeight="Bold"
                       Margin="0,0,10,0"
                       Cursor="Hand"/>

                <Button Content="Обновить" 
                       Click="ButtonRefresh_Click"
                       Width="120" Height="40"
                       FontSize="14"
                       Background="#9C27B0"
                       Foreground="White"
                       FontWeight="Bold"
                       Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>