<Page x:Class="APMC.Pages.FasCheckSmen"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:APMC.Pages"
      mc:Ignorable="d"
      d:DesignHeight="550" d:DesignWidth="900"
      Title="Проверка смены - Фасовка"
      Background="#F5F5F5"
      IsVisibleChanged="Window_IsVisibleChanged">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" 
                Background="#2196F3" 
                Padding="20"
                Height="80">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                          Text="Проверка смены сотрудников"
                          FontSize="24" 
                          FontWeight="Bold" 
                          Foreground="White"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"/>

                <TextBlock x:Name="TBHello" 
                          Grid.Column="1"
                          Text=""
                          FontSize="14" 
                          Foreground="White"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Border Grid.Row="1" 
                Margin="20"
                Background="White"
                CornerRadius="10"
                Padding="15"
                Effect="{StaticResource ShadowMedium}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок таблицы -->
                <TextBlock Grid.Row="0"
                          Text="Сотрудники на смене"
                          FontSize="18"
                          FontWeight="Bold"
                          Foreground="#2196F3"
                          Margin="0,0,0,15"
                          HorizontalAlignment="Center"/>

                <!-- Таблица с прокруткой -->
                <ScrollViewer Grid.Row="1" 
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto">
                    <DataGrid x:Name="DGridFasCheckSmenTable"
                              SelectionUnit="FullRow" 
                              SelectionMode="Single" 
                              AutoGenerateColumns="False" 
                              CanUserDeleteRows="False" 
                              IsReadOnly="False" 
                              CanUserAddRows="False" 
                              SelectionChanged="DGridFasCheckSmenTables_SelectionChanged"
                              BorderBrush="#E0E0E0"
                              BorderThickness="1"
                              RowBackground="White"
                              AlternatingRowBackground="#F8F8F8"
                              GridLinesVisibility="Horizontal"
                              FontSize="14"
                              HeadersVisibility="Column"
                              RowHeight="35">
                        <DataGrid.Resources>
                            <!-- Стиль для заголовков колонок -->
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#2196F3"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,5"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>

                            <!-- Стиль для чекбокса в таблице -->
                            <Style TargetType="CheckBox" x:Key="TableCheckBoxStyle">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Фамилия"
                                               Binding="{Binding LastName}"
                                               Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="10,5"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Имя"
                                               Binding="{Binding FirstName}"
                                               Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="10,5"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Отчество" 
                                               Binding="{Binding Patronymic}"
                                               Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="10,5"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Цех" 
                                               Binding="{Binding DepartmentID}"
                                               Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="10,5"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridCheckBoxColumn Header="Статус смены" 
                                                   Binding="{Binding IsShiftActive, 
                                                            Mode=TwoWay, 
                                                            UpdateSourceTrigger=PropertyChanged,
                                                            TargetNullValue=False}"
                                                   Width="100">
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox" BasedOn="{StaticResource TableCheckBoxStyle}"/>
                                </DataGridCheckBoxColumn.ElementStyle>
                                <DataGridCheckBoxColumn.EditingElementStyle>
                                    <Style TargetType="CheckBox" BasedOn="{StaticResource TableCheckBoxStyle}"/>
                                </DataGridCheckBoxColumn.EditingElementStyle>
                            </DataGridCheckBoxColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </ScrollViewer>

                <!-- Статистика -->
                <StackPanel Grid.Row="2" 
                           Orientation="Horizontal" 
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0">
                    <Border Background="#E3F2FD" 
                           CornerRadius="5" 
                           Padding="10,5"
                           Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👷 На смене: "
                                      FontSize="14"
                                      FontWeight="SemiBold"
                                      Foreground="#1976D2"/>
                            <TextBlock x:Name="TBActiveShifts" 
                                      Text="0"
                                      FontSize="14"
                                      FontWeight="Bold"
                                      Foreground="#1976D2"
                                      Margin="5,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F3E5F5" 
                           CornerRadius="5" 
                           Padding="10,5"
                           Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥 Всего: "
                                      FontSize="14"
                                      FontWeight="SemiBold"
                                      Foreground="#7B1FA2"/>
                            <TextBlock x:Name="TBTotalEmployees" 
                                      Text="0"
                                      FontSize="14"
                                      FontWeight="Bold"
                                      Foreground="#7B1FA2"
                                      Margin="5,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Нижняя панель с кнопками -->
        <Border Grid.Row="2" 
               Background="#E8EAF6" 
               Padding="20"
               Height="90">
            <StackPanel Orientation="Horizontal" 
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <Button Content="Сохранить изменения" 
                       Click="ButtonSave_Click"
                       Width="180" Height="45"
                       FontSize="14"
                       Background="#4CAF50"
                       Foreground="White"
                       FontWeight="Bold"
                       Margin="0,0,10,0"
                       Cursor="Hand">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                    </Button.Effect>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#45a049"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Обновить" 
                       Click="ButtonRefresh_Click"
                       Width="120" Height="45"
                       FontSize="14"
                       Background="#2196F3"
                       Foreground="White"
                       FontWeight="Bold"
                       Margin="0,0,10,0"
                       Cursor="Hand">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                    </Button.Effect>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1976D2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Назад" 
                       Click="ButtonBack_Click"
                       Width="120" Height="45"
                       FontSize="14"
                       Background="#757575"
                       Foreground="White"
                       FontWeight="Bold"
                       Cursor="Hand">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                    </Button.Effect>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#616161"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>