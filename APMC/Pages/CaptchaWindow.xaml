<Window x:Class="APMC.Pages.CaptchaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        Title="Проверка безопасности" Height="400" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Соберите пазл для продолжения"
                   FontSize="16" FontWeight="Bold"
                   Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                   HorizontalAlignment="Center" Margin="10"/>

        <!-- Область пазла -->
        <Border BorderBrush="Gray" BorderThickness="1"
                Background="LightGray" Height="162" Width="162"
                Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                Margin="10">

            <!-- Упрощенная сетка-подсказка -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>

                <!-- Ячейки-подсказки -->
                <Border Grid.Row="0" Grid.Column="0" BorderBrush="Gray"
                        BorderThickness="1"/>
                <Border Grid.Row="0" Grid.Column="1" BorderBrush="Gray"
                        BorderThickness="1"/>
                <Border Grid.Row="1" Grid.Column="0" BorderBrush="Gray"
                        BorderThickness="1"/>
                <Border Grid.Row="1" Grid.Column="1" BorderBrush="Gray"
                        BorderThickness="1"/>

                <!-- Холст для фрагментов пазла -->
                <Canvas Name="PuzzleCanvas" Grid.RowSpan="2" Grid.ColumnSpan="2"/>
            </Grid>
        </Border>

        <!-- Кнопки и результат -->
        <Button Content="Проверить" Grid.Column="1" Grid.Row="3"
                Click="ButtonCheck_Click"/>
        <Button Content="Обновить" Grid.Column="2" Grid.Row="3"
                Click="ButtonRefresh_Click"/>
        <TextBlock x:Name="ResultText" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="4"
                   FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
    </Grid>
</Window>