<Page x:Name="FasPage" x:Class="APMC.Pages.Authorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:APMC.Pages"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Авторизация"
      Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель с информацией -->
        <Border Grid.Column="0"
                Background="#2196F3">
            <StackPanel VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="40">
                <!-- Логотип (можно заменить на Image) -->
                <Border Width="100" Height="100"
                        CornerRadius="50"
                        Background="White"
                        Margin="0,0,0,30">
                    <TextBlock Text="БН"
                              FontSize="36"
                              FontWeight="Bold"
                              Foreground="#2196F3"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                </Border>

                <!-- Название компании -->
                <TextBlock Text="ООО «БАЗИС-НН»"
                          FontSize="28"
                          FontWeight="Bold"
                          Foreground="White"
                          TextAlignment="Center"
                          Margin="0,0,0,20"/>

                <!-- Описание -->
                <TextBlock Text="Система учёта продукции"
                          FontSize="18"
                          Foreground="#E3F2FD"
                          TextAlignment="Center"
                          TextWrapping="Wrap"
                          Width="300"/>
            </StackPanel>
        </Border>

        <!-- Правая панель - форма авторизации -->
        <Border Grid.Column="1"
                Background="White">
            <Grid VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Width="400">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <TextBlock Grid.Row="0"
                          Text="Авторизация"
                          FontSize="32"
                          FontWeight="Bold"
                          Foreground="#333333"
                          HorizontalAlignment="Center"/>

                <!-- Подзаголовок -->
                <TextBlock Grid.Row="2"
                          Text="Войдите в систему учёта продукции"
                          FontSize="14"
                          Foreground="#666666"
                          HorizontalAlignment="Center"
                          TextAlignment="Center"/>

                <!-- Поле логина -->
                <StackPanel Grid.Row="4">
                    <Label Content="Логин"
                          FontSize="14"
                          FontWeight="SemiBold"
                          Foreground="#333333"
                          Padding="0,0,0,5"/>
                    <TextBox x:Name="TBLogin"
                            LostFocus="TB_LostFocus"
                            Height="58"
                            FontSize="14"
                            Padding="15"
                            BorderBrush="#BDBDBD"
                            BorderThickness="1"
                            Background="White"
                            VerticalContentAlignment="Center"
                            Cursor="IBeam"
                            IsTabStop="True"
                            TabIndex="1">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="#2196F3"/>
                                    </Trigger>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="#2196F3"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>

                <!-- Поле пароля -->
                <StackPanel Grid.Row="6">
                    <Label Content="Пароль"
                          FontSize="14"
                          FontWeight="SemiBold"
                          Foreground="#333333"
                          Padding="0,0,0,5"/>
                    <PasswordBox x:Name="TBPassword"
                                LostFocus="TB_LostFocus"
                                Height="55"
                                FontSize="14"
                                Padding="15"
                                BorderBrush="#BDBDBD"
                                BorderThickness="1"
                                Background="White"
                                VerticalContentAlignment="Center"
                                Cursor="IBeam"
                                IsTabStop="True"
                                TabIndex="2">
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="#2196F3"/>
                                    </Trigger>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="#2196F3"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>
                </StackPanel>

                <!-- Сообщение об ошибке -->
                <Border Grid.Row="8"
                        x:Name="ErrorBorder"
                        Background="#FFEBEE"
                        CornerRadius="5"
                        Padding="15,10"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ErrorMessage"
                              Foreground="#D32F2F"
                              FontSize="13"
                              FontWeight="SemiBold"
                              TextWrapping="Wrap"
                              TextAlignment="Center"/>
                </Border>

                <!-- Кнопка входа -->
                <Button Grid.Row="10"
                       Content="Войти"
                       Click="ButtonEnter_Click"
                       Height="50"
                       FontSize="16"
                       FontWeight="Bold"
                       Background="#2196F3"
                       Foreground="White"
                       BorderThickness="0"
                       Cursor="Hand"
                       IsTabStop="True"
                       TabIndex="3">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1976D2"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#1565C0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Подсказка -->
                <TextBlock Grid.Row="12"
                          Text="Для входа используйте ваш логин и пароль"
                          FontSize="12"
                          Foreground="#757575"
                          HorizontalAlignment="Center"
                          TextAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Page>