<Page x:Class="APMC.Pages.AddEditUsers"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:APMC.Pages"
      mc:Ignorable="d"
      d:DesignHeight="550" d:DesignWidth="900"
      Title="Добавление/Редактирование пользователя"
      Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" 
                Background="#2196F3" 
                Padding="20"
                Height="80">
            <TextBlock Text="Добавление/Редактирование пользователя" 
                      FontSize="24" 
                      FontWeight="Bold" 
                      Foreground="White"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
        </Border>

        <!-- Основной контент -->
        <Border Grid.Row="1" 
                Margin="20"
                Background="White"
                CornerRadius="10"
                Padding="30"
                Effect="{StaticResource ShadowMedium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Левая колонка -->
                <!-- Фамилия -->
                <Label Grid.Row="0" Grid.Column="0"
                       Content="Фамилия:"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#333333"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="0,0,20,0"/>
                <TextBox x:Name="TBLastName" 
                        Grid.Row="0" Grid.Column="1"
                        Text="{Binding LastName}"
                        LostFocus="TB_LostFocus"
                        Height="40"
                        FontSize="14"
                        Padding="10"
                        BorderBrush="#BDBDBD"
                        BorderThickness="1"
                        Background="White"
                        VerticalContentAlignment="Center"
                        Cursor="IBeam">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#2196F3"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="#2196F3"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Имя -->
                <Label Grid.Row="2" Grid.Column="0"
                       Content="Имя:"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#333333"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="0,0,20,0"/>
                <TextBox x:Name="TBFirstName" 
                        Grid.Row="2" Grid.Column="1"
                        Text="{Binding FirstName}"
                        LostFocus="TB_LostFocus"
                        Height="40"
                        FontSize="14"
                        Padding="10"
                        BorderBrush="#BDBDBD"
                        BorderThickness="1"
                        Background="White"
                        VerticalContentAlignment="Center"
                        Cursor="IBeam">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#2196F3"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="#2196F3"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Отчество -->
                <Label Grid.Row="4" Grid.Column="0"
                       Content="Отчество:"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#333333"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="0,0,20,0"/>
                <TextBox x:Name="TBPatronymic" 
                        Grid.Row="4" Grid.Column="1"
                        Text="{Binding Patronymic}"
                        LostFocus="TB_LostFocus"
                        Height="40"
                        FontSize="14"
                        Padding="10"
                        BorderBrush="#BDBDBD"
                        BorderThickness="1"
                        Background="White"
                        VerticalContentAlignment="Center"
                        Cursor="IBeam">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#2196F3"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="#2196F3"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Правая колонка -->
                <!-- Логин -->
                <Label Grid.Row="0" Grid.Column="3"
                       Content="Логин:"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#333333"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="0,0,20,0"/>
                <TextBox x:Name="TBLoginNew" 
                        Grid.Row="0" Grid.Column="4"
                        Text="{Binding UserLogin}"
                        LostFocus="TB_LostFocus"
                        Height="40"
                        FontSize="14"
                        Padding="10"
                        BorderBrush="#BDBDBD"
                        BorderThickness="1"
                        Background="White"
                        VerticalContentAlignment="Center"
                        Cursor="IBeam">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#2196F3"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="#2196F3"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Пароль -->
                <Label Grid.Row="2" Grid.Column="3"
                       Content="Пароль:"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#333333"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="0,0,20,0"/>
                <TextBox x:Name="TBPasswordNew" 
                        Grid.Row="2" Grid.Column="4"
                        Text="{Binding UserPassword}"
                        LostFocus="TB_LostFocus"
                        Height="40"
                        FontSize="14"
                        Padding="10"
                        BorderBrush="#BDBDBD"
                        BorderThickness="1"
                        Background="White"
                        VerticalContentAlignment="Center"
                        Cursor="IBeam">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#2196F3"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="#2196F3"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Роль -->
                <Label Grid.Row="4" Grid.Column="3"
                       Content="Роль:"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#333333"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="0,0,20,0"/>
                <ComboBox x:Name="CBRole" 
                         Grid.Row="4" Grid.Column="4"
                         SelectedValue="{Binding UserRole}"
                         DisplayMemberPath="RoleName"
                         SelectedValuePath="RoleID"
                         SelectionChanged="CBRole_SelectionChanged"
                         Height="40"
                         FontSize="14"
                         Padding="10,0,10,0"
                         BorderBrush="#BDBDBD"
                         BorderThickness="1"
                         Background="White"
                         VerticalContentAlignment="Center">
                    <ComboBox.Effect>
                        <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.2"/>
                    </ComboBox.Effect>
                </ComboBox>

                <!-- Статус пользователя -->
                <Label Grid.Row="6" Grid.Column="0"
                       Content="Статус:"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#333333"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="0,0,20,0"/>
                <ComboBox x:Name="CBUserStatus" 
                         Grid.Row="6" Grid.Column="1"
                         SelectedValue="{Binding UserStatus}"
                         DisplayMemberPath="UserStatusName"
                         SelectedValuePath="UserStatusID"
                         Height="40"
                         FontSize="14"
                         Padding="10,0,10,0"
                         BorderBrush="#BDBDBD"
                         BorderThickness="1"
                         Background="White"
                         VerticalContentAlignment="Center">
                    <ComboBox.Effect>
                        <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.2"/>
                    </ComboBox.Effect>
                </ComboBox>

                <!-- Цех -->
                <Label Grid.Row="6" Grid.Column="3"
                       Content="Цех:"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#333333"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="0,0,20,0"/>
                <ComboBox x:Name="CBdep" 
                         Grid.Row="6" Grid.Column="4"
                         SelectedValue="{Binding DepartmentID}"
                         DisplayMemberPath="DepartmentName"
                         SelectedValuePath="DepartmentID"
                         Height="40"
                         FontSize="14"
                         Padding="10,0,10,0"
                         BorderBrush="#BDBDBD"
                         BorderThickness="1"
                         Background="White"
                         VerticalContentAlignment="Center">
                    <ComboBox.Effect>
                        <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.2"/>
                    </ComboBox.Effect>
                </ComboBox>

                <!-- Сообщение об ошибке -->
                <Border Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="5"
                        x:Name="ErrorBorder"
                        Background="#FFEBEE"
                        CornerRadius="5"
                        Padding="15,10"
                        Margin="0,20,0,0"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ErrorMessage"
                              Foreground="#D32F2F"
                              FontSize="13"
                              FontWeight="SemiBold"
                              TextWrapping="Wrap"
                              TextAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Нижняя панель с кнопками -->
        <Border Grid.Row="2" 
               Background="#E8EAF6" 
               Padding="20"
               Height="90">
            <StackPanel Orientation="Horizontal" 
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <Button x:Name="BtnSave" 
                       Content="Сохранить" 
                       Click="ButtonOKAddEdit1_Click"
                       Width="180" Height="50"
                       FontSize="16"
                       Background="#4CAF50"
                       Foreground="White"
                       FontWeight="Bold"
                       Margin="0,0,20,0"
                       Cursor="Hand">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                    </Button.Effect>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#45a049"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="BtnCancel"
                       Content="Отмена" 
                       Click="ButtonCancel_Click"
                       Width="180" Height="50"
                       FontSize="16"
                       Background="#757575"
                       Foreground="White"
                       FontWeight="Bold"
                       Cursor="Hand">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                    </Button.Effect>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#616161"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>