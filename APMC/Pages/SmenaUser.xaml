<Page x:Class="APMC.Pages.SmenaUser"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Рабочая смена" 
      Height="400" Width="600"
      Background="#F5F5F5">

    <Grid Margin="0,0,0,-49">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2196F3" Padding="20">
            <StackPanel>
                <TextBlock Text="Учет рабочей смены" 
                          FontSize="24" 
                          FontWeight="Bold" 
                          Foreground="White"
                          HorizontalAlignment="Center"/>
                <TextBlock x:Name="UserNameText" 
                          FontSize="16" 
                          Foreground="White"
                          HorizontalAlignment="Center"
                          Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Основной контент -->
        <StackPanel Grid.Row="1" 
                   VerticalAlignment="Center" 
                   HorizontalAlignment="Center"
                   Margin="20">

            <!-- Большой чекбокс -->
            <Border BorderBrush="#2196F3" 
                   BorderThickness="3" 
                   CornerRadius="10"
                   Padding="40"
                   Background="White"
                   Effect="{StaticResource ShadowMedium}" Height="137">
                <StackPanel>
                    <CheckBox x:Name="ShiftCheckBox"  
                             Content="Я на смене"
                             FontSize="36"
                             FontWeight="Bold"
                             Foreground="#2196F3"
                             IsChecked="{Binding IsOnShift, Mode=TwoWay}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <CheckBox.Template>
                            <ControlTemplate TargetType="CheckBox">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Большая галочка -->
                                    <Border x:Name="checkBoxBorder" 
                                           Grid.Column="0"
                                           Width="50" 
                                           Height="50" 
                                           Margin="0,0,20,0"
                                           BorderBrush="#2196F3" 
                                           BorderThickness="3"
                                           CornerRadius="5"
                                           Background="White">
                                        <TextBlock x:Name="checkMark"
                                                  Text="✓"
                                                  FontSize="40"
                                                  FontWeight="Bold"
                                                  Foreground="#2196F3"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Visibility="Collapsed"/>
                                    </Border>

                                    <!-- Текст -->
                                    <TextBlock Grid.Column="1"
                                              Text="{TemplateBinding Content}"
                                              FontSize="{TemplateBinding FontSize}"
                                              FontWeight="{TemplateBinding FontWeight}"
                                              Foreground="{TemplateBinding Foreground}"
                                              VerticalAlignment="Center"/>
                                </Grid>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="checkBoxBorder" Property="Background" Value="#E3F2FD"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="checkBoxBorder" Property="Background" Value="#E3F2FD"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </CheckBox.Template>
                    </CheckBox>

                    <!-- Статус -->
                    <TextBlock x:Name="StatusText" 
                              FontSize="18"
                              HorizontalAlignment="Center"
                              Margin="0,20,0,0"
                              TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Инструкция -->
            <TextBlock Text="Нажмите на галочку, чтобы отметить начало или окончание смены" 
                      FontSize="14" 
                      Foreground="Gray"
                      HorizontalAlignment="Center"
                      Margin="0,30,0,0"
                      TextWrapping="Wrap"
                      TextAlignment="Center"
                      Width="400"/>
        </StackPanel>

        <!-- Панель кнопок -->
        <StackPanel Grid.Row="2" 
                   Orientation="Horizontal" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,40">

            <Button Content="Сохранить статус" 
                   Click="ButtonSave_Click"
                   Width="150" Height="40"
                   FontSize="16"
                   Background="#4CAF50"
                   Foreground="White"
                   FontWeight="Bold"
                   >
                <Button.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                </Button.Effect>
            </Button>

            <Button Content="Выход" 
                   Click="ButtonExit_Click"
                   Width="100" Height="40"
                   FontSize="16"
                   Margin="10">
                <Button.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                </Button.Effect>
            </Button>
        </StackPanel>
    </Grid>
</Page>